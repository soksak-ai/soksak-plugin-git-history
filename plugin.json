{
  "spec": "soksak-plugin-spec@1",
  "id": "soksak-plugin-git-history",
  "name": { "en": "Git History", "ko": "깃 히스토리" },
  "version": "1.0.3",
  "repo": "https://github.com/soksak-ai/soksak-plugin-git-history.git",
  "description": { "en": "Project commit history sidebar — click a commit to show changed files and patch.", "ko": "프로젝트 커밋 이력 사이드바 — 커밋을 클릭하면 변경 파일 목록과 패치를 표시." },
  "permissions": [
    "ui",
    "git:read",
    "terminal"
  ],
  "contributes": {
    "views": [
      {
        "id": "history",
        "title": { "en": "Git History", "ko": "깃 히스토리" },
        "icon": "⎇",
        "placements": [
          "sidebar-right"
        ]
      }
    ],
    "nodes": [
      {
        "id": "commit",
        "description": "커밋 행 (클릭하면 상세 보기). data-node=commit/<커밋 해시>"
      },
      {
        "id": "more",
        "description": "더 보기 버튼 (다음 페이지 로드)"
      },
      {
        "id": "refresh",
        "description": "새로고침 버튼 (목록 처음부터 재로드)"
      }
    ]
  }
}
